<!DOCTYPE html>
<html>
  <head>
    <title>rails-llm</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "rails_llm/application", media: "all" %>
    <%= javascript_include_tag "rails_llm/application", defer: true %>
    <%= yield :head %>
  </head>
  <body>
    <div class="layout">
      <div class="sidebar">
        <div class="brand">
          <div class="product-sub">AGENTS</div>
        </div>
        <%= link_to agents_path, method: :post,
              class: "new-agent" do %>
          <span class="plus">+</span>
          <span>New Agent</span>
        <% end %>
        <nav>
          <% if @agents %>
            <% @agents.each do |agent| %>
              <%= link_to agent.title_or_default, agent_path(agent),
                    class: "agent-link #{'active' if agent == @agent}" %>
            <% end %>
          <% end %>
        </nav>
        <a href="https://github.com/llmrb/llm.rb#readme"
           class="powered-by" target="_blank" rel="noopener">
          Powered by llm.rb
        </a>
      </div>
      <div class="main">
        <%= yield %>
      </div>
    </div>
  </body>
</html>
